# 复制为 .env 后填写真实值。.env 已被 .gitignore 忽略，不会进仓库。

# === SSH 默认凭据（所有节点共用时填这里）===
SSH_DEFAULT_USERNAME=root
SSH_DEFAULT_PASSWORD=changeme
# 或使用密钥（容器内路径，需在 compose 里挂载）：
# SSH_DEFAULT_KEY_PATH=/app/keys/id_rsa

# === 逐节点密码覆盖（可选）===
# 变量名格式 NODE_<节点ID大写>_PASSWORD
# NODE_NETUNIT1_PASSWORD=xxxx
# NODE_HOST1_PASSWORD=xxxx

# === 数据库（默认 SQLite，无需改）===
# DATABASE_URL=sqlite:////app/data/control_plane.db
# 切 MySQL 示例：
# DATABASE_URL=mysql+pymysql://user:pass@10.130.131.239:3306/control_plane

SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=600
